{
    "name": "BA Project",
    "doctype": "DocType",
    "module": "BizAxl Projects",
    "autoname": "naming_series:",
    "naming_series": "PROJ-.YYYY.-",
    "title_field": "project_name",
    "search_fields": "project_name,customer,status",
    "fields": [
        {"fieldname": "naming_series", "fieldtype": "Select", "options": "PROJ-.YYYY.-"},
        {"fieldname": "project_name", "fieldtype": "Data", "label": "Project Name", "reqd": 1, "in_list_view": 1},
        {"fieldname": "project_type", "fieldtype": "Link", "label": "Project Type", "options": "BA Project Type"},
        {"fieldname": "status", "fieldtype": "Select", "label": "Status",
         "options": "Open\nCompleted\nCancelled\nOn Hold", "default": "Open", "in_list_view": 1},
        {"fieldname": "col1", "fieldtype": "Column Break"},
        {"fieldname": "company", "fieldtype": "Link", "label": "Company", "options": "BA Company", "reqd": 1},
        {"fieldname": "customer", "fieldtype": "Link", "label": "Customer", "options": "BA Customer", "in_list_view": 1},
        {"fieldname": "assigned_to", "fieldtype": "Link", "label": "Project Manager", "options": "User"},
        {"fieldname": "sec_dates", "fieldtype": "Section Break", "label": "Dates & Budget"},
        {"fieldname": "expected_start_date", "fieldtype": "Date", "label": "Expected Start", "in_list_view": 1},
        {"fieldname": "expected_end_date", "fieldtype": "Date", "label": "Expected End", "in_list_view": 1},
        {"fieldname": "actual_start_date", "fieldtype": "Date", "label": "Actual Start"},
        {"fieldname": "actual_end_date", "fieldtype": "Date", "label": "Actual End"},
        {"fieldname": "col2", "fieldtype": "Column Break"},
        {"fieldname": "estimated_costing", "fieldtype": "Currency", "label": "Estimated Cost"},
        {"fieldname": "total_costing_amount", "fieldtype": "Currency", "label": "Total Costing", "read_only": 1},
        {"fieldname": "total_billing_amount", "fieldtype": "Currency", "label": "Total Billed", "read_only": 1},
        {"fieldname": "gross_margin", "fieldtype": "Currency", "label": "Gross Margin", "read_only": 1},
        {"fieldname": "per_gross_margin", "fieldtype": "Percent", "label": "Gross Margin %", "read_only": 1},
        {"fieldname": "sec_progress", "fieldtype": "Section Break", "label": "Progress"},
        {"fieldname": "percent_complete_method", "fieldtype": "Select", "label": "% Complete Method",
         "options": "Manual\nTask Completion\nTask Progress", "default": "Manual"},
        {"fieldname": "percent_complete", "fieldtype": "Percent", "label": "% Complete", "default": "0"},
        {"fieldname": "priority", "fieldtype": "Select", "label": "Priority",
         "options": "Low\nMedium\nHigh\nUrgent", "default": "Medium"},
        {"fieldname": "description", "fieldtype": "Text Editor", "label": "Description"},
        {"fieldname": "notes", "fieldtype": "Text Editor", "label": "Notes"}
    ],
    "permissions": [
        {"role": "System Manager", "read": 1, "write": 1, "create": 1, "delete": 1},
        {"role": "Projects Manager", "read": 1, "write": 1, "create": 1},
        {"role": "Projects User", "read": 1, "write": 1, "create": 1},
        {"role": "Sales User", "read": 1}
    ]
}
